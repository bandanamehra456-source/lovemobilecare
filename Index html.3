<!DOCTYPE html>
<html>
<head>
    <title>Love Mobile Care Center</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: #0f0f0f;
            color: white;
        }

        header {
            background: linear-gradient(to right, red, darkred);
            padding: 20px;
            text-align: center;
        }

        .container {
            padding: 15px;
        }

        h2 {
            text-align: center;
        }

        .products {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
        }

        .card {
            background: #1c1c1c;
            padding: 15px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 0 10px rgba(255,0,0,0.3);
        }

        .card img {
            width: 100%;
            border-radius: 10px;
        }

        .btn {
            display: block;
            margin-top: 10px;
            padding: 10px;
            background: green;
            color: white;
            border-radius: 8px;
            text-decoration: none;
        }

        .call-btn {
            background: blue;
        }

        .services ul {
            list-style: none;
            padding: 0;
        }

        .services li {
            background: #222;
            margin: 5px;
            padding: 10px;
            border-radius: 8px;
        }

        footer {
            background: #111;
            text-align: center;
            padding: 15px;
            margin-top: 20px;
        }

    </style>
</head>

<body>

<header>
    <h1>Love Mobile Care 📱</h1>
    <p>Accessories & Repair Solutions</p>
</header>

<div class="container">

    <h2>Our Products</h2>

    <div class="products">

        <div class="card">
            <img src="https://via.placeholder.com/150">
            <h3>Mobile Cover</h3>
            <p>₹199</p>
            <a class="btn" href="https://wa.me/916284638326?text=Hello%20I%20want%20to%20order%20Mobile%20Cover">Buy Now</a>
        </div>

        <div class="card">
            <img src="https://via.placeholder.com/150">
            <h3>Tempered Glass</h3>
            <p>₹99</p>
            <a class="btn" href="https://wa.me/916284638326?text=Hello%20I%20want%20to%20order%20Tempered%20Glass">Buy Now</a>
        </div>

        <div class="card">
            <img src="https://via.placeholder.com/150">
            <h3>Fast Charger</h3>
            <p>₹499</p>
            <a class="btn" href="https://wa.me/916284638326?text=Hello%20I%20want%20to%20order%20Charger">Buy Now</a>
        </div>

    </div>

    <div class="services">
        <h2>Our Services</h2>
        <ul>
            <li>📱 Mobile Repair</li>
            <li>🔧 Screen Replacement</li>
            <li>🔋 Battery Change</li>
        </ul>
    </div>

</div>

<footer>

    <p>📱 Love Mobile Care Center</p>

    <p>📍 Shop No 02, Chandigarh Rd, near Lucky Shaba, Main Market, Jandiali, Ludhiana, Punjab 141112</p>

    <p>📞 +91 6284638326</p>

    <a class="btn" href="https://wa.me/916284638326?text=Hello%20Love%20Mobile%20Care,%20I%20want%20to%20order">
        💬 Order on WhatsApp
    </a>

    <a class="btn call-btn" href="tel:+916284638326">
        📞 Call Now
    </a>

    <br><br>

    <iframe 
    src="https://www.google.com/maps?q=Shop%20No%2002,%20Chandigarh%20Rd,%20Jandiali,%20Ludhiana&output=embed" 
    width="100%" 
    height="200" 
    style="border:0;">
    </iframe>

</footer>

</body>
</html>
